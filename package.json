{
  "name": "sluggit",
  "version": "1.3.0",
  "description": "A utility for generating slugs from text strings in TypeScript.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "url": "git+https://github.com/misbahul-alam/sluggit.git",
    "type": "git"
  },
  "scripts": {
    "build": "tsup",
